upstream peoplegraph_frontend {
    server frontend:3000;
}

upstream peoplegraph_backend {
    server backend:8000;
}

server {
    listen 80;
    server_name peoplegraph.co www.peoplegraph.co;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name peoplegraph.co www.peoplegraph.co;

    ssl_certificate /etc/letsencrypt/live/peoplegraph.co/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/peoplegraph.co/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:PeopleGraphSSL:10m;
    ssl_session_tickets off;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    client_max_body_size 1m;

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host $host;

    location /api/ {
        proxy_pass http://peoplegraph_backend;
    }

    location /django-static/ {
        proxy_pass http://peoplegraph_backend;
    }

    location = /admin {
        return 301 /admin/;
    }

    location /admin/ {
        proxy_pass http://peoplegraph_backend;
    }

    location / {
        proxy_pass http://peoplegraph_frontend;
    }
}
